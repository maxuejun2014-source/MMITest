            android:theme="@style/Theme.MMITest" />

        <activity
            android:name=".ui.testitems.HeadphoneTestActivity"
            android:exported="false"
            android:label="耳机回环测试"
            android:theme="@style/Theme.MMITest" />

        <activity
            android:name=".ui.testitems.FmTestActivity"
            android:exported="false"
            android:label="FM测试"
            android:theme="@style/Theme.MMITest" />

        <activity
            android:name=".ui.testitems.FrontCameraTestActivity"
            android:exported="false"
            android:label="前摄测试"
            android:theme="@style/Theme.MMITest" />

        <activity
            android:name=".ui.testitems.RearCameraTestActivity"
            android:exported="false"
            android:label="后摄测试"
            android:theme="@style/Theme.MMITest" />

        <activity
            android:name=".ui.testitems.PhoneTestActivity"
            android:exported="false"
            android:label="电话测试"
            android:theme="@style/Theme.MMITest" />

        <activity
            android:name=".ui.testitems.WifiTestActivity"
            android:exported="false"
            android:label="WiFi测试"
            android:theme="@style/Theme.MMITest" />

        <activity
            android:name=".ui.testitems.BluetoothTestActivity"
            android:exported="false"
            android:label="蓝牙测试"
            android:theme="@style/Theme.MMITest" />

        <activity
            android:name=".ui.testitems.GpsTestActivity"
            android:exported="false"
            android:label="GPS测试"
            android:theme="@style/Theme.MMITest" />

        <activity
            android:name=".ui.testitems.OtgTestActivity"
            android:exported="false"
            android:label="OTG测试"
            android:theme="@style/Theme.MMITest" />

        <activity
            android:name=".ui.testitems.ProximitySensorTestActivity"
            android:exported="false"
            android:label="距离传感器测试"
            android:theme="@style/Theme.MMITest" />

    </application>

</manifest>
